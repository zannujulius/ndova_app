{
  "name": "ndova-backend",
  "version": "1.0.0",
  "description": "Service Request and Appointment Management System — Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "db:setup": "bash scripts/db-setup.sh",
    "db:migrate": "node -r ts-node/register ./node_modules/.bin/sequelize-cli db:migrate",
    "db:migrate:docker": "sequelize-cli db:migrate --config src/db/config.js --migrations-path dist/db/migrations",
    "db:migrate:undo": "node -r ts-node/register ./node_modules/.bin/sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "node -r ts-node/register ./node_modules/.bin/sequelize-cli db:migrate:undo:all",
    "db:seed": "ts-node src/db/seed.ts",
    "db:seed:docker": "node dist/db/seed.js",
    "db:studio": "echo 'Use a GUI like TablePlus, DBeaver, or pgAdmin to inspect the database.'"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
